{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Textface Parts Manifest",
  "type": "object",
  "required": ["categories", "parts"],
  "additionalProperties": false,
  "properties": {
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["head", "eyes", "nose", "mouth", "hair", "facial_hair"]
      },
      "minItems": 6,
      "maxItems": 6
    },
    "parts": {
      "type": "array",
      "items": { "$ref": "#/definitions/part" },
      "minItems": 1
    }
  },
  "definitions": {
    "part": {
      "type": "object",
      "required": ["id", "category", "anchor", "rows"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "category": {
          "type": "string",
          "enum": ["head", "eyes", "nose", "mouth", "hair", "facial_hair"]
        },
        "anchor": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "integer", "minimum": 0, "maximum": 19 },
            "y": { "type": "integer", "minimum": 0, "maximum": 19 }
          }
        },
        "rows": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
}
